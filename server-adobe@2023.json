{
    "name":"rememberme-adobe@2023",
    "app":{
        "serverHomeDirectory":".engine/adobe2023",
        "cfengine":"adobe@2023"
    },
    "web":{
        "http":{
            "port":"60305"
        },
        "rewrites":{
            "enable":"true"
        },
        "allowedExt":"webmanifest,avif",
        "webroot":"test-harness",
        "aliases":{
            "/moduleroot/rememberme":"./",
            "/modules/rememberme":"./"
        }
    },
    "jvm":{
        "heapSize":"1024",
        "args":[
            "-Dcoldfusion.runtime.remotemethod.matchArguments=false"
        ]
    },
    "openBrowser":false,
    "cfconfig":{
        "file":".cfconfig.json"
    },
    "scripts":{
        "onServerInstall":"cfpm install zip,debugger,sqlserver"
    }
}
