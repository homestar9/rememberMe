{
    "name":"rememberme-boxlang@1",
    "app":{
        "serverHomeDirectory":".engine/boxlang-cfml",
        "cfengine":"boxlang@1"
    },
    "fusionreactor":{
        "enable":false
    },
    "web":{
        "http":{
            "port":"60305"
        },
        "rewrites":{
            "enable":true
        },
        "webroot":"test-harness",
        "aliases":{
            "/moduleroot/rememberme":"./",
            "/modules/rememberme":"./"
        }
    },
    "JVM":{
        "heapSize":"768",
        "javaVersion":"openjdk21_jre",
        "args":"-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=8888"
    },
    "openBrowser":false,
    "cfconfig":{
        "file":".cfconfig.json"
    },
    "env":{},
    "scripts":{
        "onServerInitialInstall":"install bx-compat-cfml,bx-mssql --noSave"
    }
}